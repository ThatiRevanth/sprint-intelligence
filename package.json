{
  "name": "sprint-intelligence",
  "version": "1.0.1",
  "description": "Sprint Intelligence & Flow Optimizer - Azure DevOps Extension",
  "private": true,
  "scripts": {
    "start": "webpack serve --mode development --port 3000",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "package": "node scripts/bump-version.js && npm run build && npx tfx extension create --manifest-globs vss-extension.json --output-path ./dist",
    "package:dev": "node scripts/bump-version.js && npm run build:dev && npx tfx extension create --manifest-globs vss-extension.dev.json --output-path ./dist",
    "publish": "npm run package && npx tfx extension publish --manifest-globs vss-extension.json"
  },
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "azure-devops-extension-api": "^4.234.0",
    "azure-devops-extension-sdk": "^4.0.2",
    "chart.js": "^4.4.0",
    "ng2-charts": "^6.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/compiler-cli": "^20.0.0",
    "@types/node": "^22.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "sass": "^1.80.0",
    "sass-loader": "^16.0.0",
    "style-loader": "^4.0.0",
    "tfx-cli": "^0.17.0",
    "ts-loader": "^9.5.0",
    "typescript": "~5.8.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0",
    "webpack-dev-server": "^5.2.3"
  }
}
